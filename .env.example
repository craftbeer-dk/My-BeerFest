# Nginx - Port and authentication
PORT=8181
STATS_USER=stats
STATS_PASSWORD=changeme
ADMIN_USER=admin
ADMIN_PASSWORD=changeme

# PHP - Festival configuration
DOMAIN=beerfest.craftbeer.dk
FESTIVAL_TITLE=Lorem Ipsum Festival 2025
FESTIVAL_TITLE_SHORT=Lorem Ipsum '25
APP_LANGUAGE=da
ENABLE_MAINSTYLE_FILTERING=true
FESTIVAL_INFO_TEXT=Welcome to Lorem Ipsum Festival 2025
ENABLE_STATISTICS_LOGGING=true
CONTACT_EMAIL=lorem@example.com
DEV_MODE=false
UNTAPPD_RATE_WINDOW=30
UNTAPPD_RATE_MAX=15
UNTAPPD_RATE_COOLDOWN=2

# PHP - Coming-soon gate
# Set NOT_PUBLIC=true to show a "coming soon" page instead of the app.
# Share /?key=<NOT_PUBLIC_BYPASS_KEY> to grant a preview cookie (30 days).
# FESTIVAL_DATE must be RFC3339 for the countdown to render.
NOT_PUBLIC=false
NOT_PUBLIC_BYPASS_KEY=
FESTIVAL_DATE=
SHOW_COUNTDOWN=false
